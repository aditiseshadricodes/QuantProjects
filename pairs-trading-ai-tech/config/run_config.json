{
    "project":{
        "name":"pairs_trading"
    },
    "date_range":{
        "start_date":"2020-01-01",
        "end_date":"2024-12-31"
    },
    "data_loader":{
        "price_field":"adjClose",
        "volume_field":"adjVolume",
        "validate":true,
        "missing_threshold":0.05
    },
    "data_files":{
        "processed_dir":"data/processed",
        "price_matrix":"price_matrix",
        "volume_matrix":"volume_matrix",
        "dollar_volume_matrix":"dollar_volume_matrix",
        "csv_extension":".csv"
    },
    "pairs_selection":{
        "top_n":5,
        "min_observations":60,
        "min_correlation":0.4,
        "pvalue_threshold":0.05,
        "trend":"c",
        "use_log_prices":true,
        "max_half_life":60,
        "min_avg_dollar_volume":10000000
    },
    "spread_model":{
        "z_score_window":60
    },
    "backtest":{
        "entry_threshold":2.0,
        "exit_threshold":0.5,
        "transaction_cost_bps":20,
        "min_observations":60,
        "selected_pair_mode":"top_cointegration_passing_pair"
    }    
}